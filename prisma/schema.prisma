 generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  username   String   @unique
  firstName  String?
  lastName   String?
  email      String   @unique
  imageUrl   String?
  bio        String?
  createdAt  DateTime @default(now())

  posts      Post[]
}

model Post {
  id         String   @id @default(cuid())
  content    String
  imageUrl   String?
  createdAt  DateTime @default(now())

  userId     String
  user       User @relation(fields: [userId], references: [id])
}